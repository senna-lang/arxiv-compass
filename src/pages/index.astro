---
/**
 * トップページ
 *
 * 利用可能な最新日付のページにリダイレクトする。
 * データがない場合はセットアップ案内を表示する。
 */
import MainLayout from "../layouts/MainLayout.astro";
import { extractDates } from "../lib/data";

const files = import.meta.glob("/data/????????.json");
const dates = extractDates(files);
const latestDate = dates.length > 0 ? dates[dates.length - 1] : null;
---

<MainLayout title="arXiv新聞">
  {latestDate && <meta http-equiv="refresh" content={`0; url=/${latestDate}`} slot="head" />}
  {
    latestDate ? (
      <p>Redirecting to <a href={`/${latestDate}`}>{latestDate}</a>...</p>
    ) : (
      <>
        <h1>📰 arXiv新聞</h1>
        <p>まだデータがありません。<code>python scripts/parse.py</code> を実行してください。</p>
      </>
    )
  }
</MainLayout>
